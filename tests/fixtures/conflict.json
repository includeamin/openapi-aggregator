{
  "openapi": "3.0.3",
  "info": {
    "title": "Another Pet API",
    "version": "2.0.0"
  },
  "paths": {
    "/pets": {
      "get": {
        "summary": "List animals",
        "operationId": "listAnimals",
        "responses": {
          "200": {
            "description": "A list of animals",
            "content": {
              "application/json": {
                "schema": {
                  "type": "array",
                  "items": {
                    "$ref": "#/components/schemas/Pet"
                  }
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "Pet": {
        "type": "object",
        "required": ["id", "species"],
        "properties": {
          "id": {
            "type": "integer",
            "format": "int64"
          },
          "species": {
            "type": "string"
          }
        }
      }
    }
  }
}
